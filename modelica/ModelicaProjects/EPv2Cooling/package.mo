within ModelicaProjects;
package EPv2Cooling "EPv2 冷却系スタディ"
  extends Modelica.Icons.ExamplesPackage;
  annotation (Documentation(info="<html>
<p>EPv2 冷却系の検討用パッケージ。</p>
<h4>構成</h4>
<ul>
<li><code>Study</code> — モジュール単体・システム全体の検討モデル</li>
<li><code>Component</code> — モーター・インバーター冷却モジュールのサブモデル</li>
<li><code>SpeedProfile</code> — 回転数プロファイルの確認モデル</li>
</ul>
</html>"));
end EPv2Cooling;
