within ModelicaProjects.EPv2Cooling;
package Component "モーター・インバーター冷却モジュールのサブモデル"
  extends Modelica.Icons.ExamplesPackage;
  annotation (Documentation(info="<html>
<h4>現在のモデル</h4>
<ul>
<li><code>MotorCoolingModule</code> — モーター冷却モジュール（円筒熱伝導 + 冷却管）</li>
<li><code>InvertorCoolingModule</code> — インバーター冷却モジュール（モジュール群 + 冷却管）</li>
</ul>
</html>"));
end Component;
